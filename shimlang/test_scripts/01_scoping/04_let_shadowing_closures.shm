// A `let` may shadow a variable declared earlier in the same scope.
// Closures created before the shadowing only see the original binding,
// while closures created after see the new one.

let x = 1;
let read_first = fn() { x };
let x = 2;
let read_second = fn() { x };
print(read_first());
print(read_second());
print(x);

// The shadowing initializer sees the previous binding.
let y = 10;
let cap = fn() { y };
let y = y + 5;
print(cap());
print(y);

// Shadowing also works inside function bodies.
fn make() {
    let a = 100;
    let old = fn() { a };
    let a = 200;
    [old, fn() { a }]
}
let fns = make();
print(fns[0]());
print(fns[1]());

// Reassignment to the new binding doesn't affect closures over the old one.
let z = 1;
let before = fn() { z };
let z = 2;
z = 3;
print(before());
print(z);

// Forward references and mutual recursion still work across a shadowing `let`:
// shadowing must not hide later declarations from earlier-defined functions.
fn is_even(n) { if n == 0 { true } else { is_odd(n - 1) } }
let depth = 1;
let depth = 2;
fn is_odd(n) { if n == 0 { false } else { is_even(n - 1) } }
print(is_even(4));
print(is_odd(4));

// A function declared before a shadow can still call one declared after it.
fn caller() { callee() }
let tag = "a";
let tag = "b";
fn callee() { 7 }
print(caller());

// A `let` can shadow a function parameter.
fn shadow_param(p) {
    let see_param = fn() { p };
    let p = p + 1;
    [see_param(), p]
}
let sp = shadow_param(41);
print(sp[0]);
print(sp[1]);
