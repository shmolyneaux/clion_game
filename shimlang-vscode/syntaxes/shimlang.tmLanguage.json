{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Shimlang",
    "scopeName": "source.shim",
    "fileTypes": ["shm"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#string" },
        { "include": "#function-definition" },
        { "include": "#struct-definition" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#function-call" },
        { "include": "#self-keyword" },
        { "include": "#operators" },
        { "include": "#round-braces" },
        { "include": "#square-braces" },
        { "include": "#curly-braces" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "include": "#line-comment" },
                { "include": "#block-comment" }
            ]
        },
        "line-comment": {
            "name": "comment.line.double-slash.shim",
            "match": "//.*$"
        },
        "block-comment": {
            "name": "comment.block.shim",
            "begin": "/\\*",
            "end": "\\*/",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.comment.begin.shim" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.comment.end.shim" }
            },
            "patterns": [
                { "include": "#block-comment" }
            ]
        },
        "string": {
            "name": "string.quoted.double.shim",
            "begin": "\"",
            "end": "\"",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.shim" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.shim" }
            },
            "patterns": [
                { "include": "#string-interpolation" },
                { "include": "#escape-sequence" }
            ]
        },
        "string-interpolation": {
            "name": "meta.interpolation.shim",
            "contentName": "source.shim.embedded",
            "begin": "\\\\\\(",
            "end": "\\)",
            "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.shim" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.shim" }
            },
            "patterns": [
                { "include": "$self" }
            ]
        },
        "escape-sequence": {
            "name": "constant.character.escape.shim",
            "match": "\\\\[nrt\\\\\"']"
        },
        "function-definition": {
            "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
            "captures": {
                "1": { "name": "storage.type.function.shim" },
                "2": { "name": "entity.name.function.shim" }
            }
        },
        "struct-definition": {
            "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "storage.type.struct.shim" },
                "2": { "name": "entity.name.type.shim" }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.shim",
                    "match": "\\b(if|else|while|for|in|break|continue|return)\\b"
                },
                {
                    "name": "keyword.other.let.shim",
                    "match": "\\blet\\b"
                },
                {
                    "name": "keyword.operator.logical.shim",
                    "match": "\\b(and|or)\\b"
                },
                {
                    "name": "storage.type.function.shim",
                    "match": "\\bfn\\b"
                },
                {
                    "name": "storage.type.struct.shim",
                    "match": "\\bstruct\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.true.shim",
                    "match": "\\btrue\\b"
                },
                {
                    "name": "constant.language.boolean.false.shim",
                    "match": "\\bfalse\\b"
                },
                {
                    "name": "constant.language.none.shim",
                    "match": "\\bNone\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.shim",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.shim",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "function-call": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
            "captures": {
                "1": { "name": "entity.name.function.call.shim" }
            }
        },
        "self-keyword": {
            "name": "variable.language.self.shim",
            "match": "\\bself\\b"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.shim",
                    "match": "==|!=|>=|<=|>|<"
                },
                {
                    "name": "keyword.operator.assignment.shim",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arithmetic.shim",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.range.shim",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.logical.not.shim",
                    "match": "!"
                },
                {
                    "name": "keyword.operator.accessor.shim",
                    "match": "\\."
                }
            ]
        },
        "round-braces": {
            "begin": "\\(",
            "end": "\\)",
            "beginCaptures": {
                "0": { "name": "punctuation.section.parens.begin.shim" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.section.parens.end.shim" }
            },
            "patterns": [
                { "include": "$self" }
            ]
        },
        "square-braces": {
            "begin": "\\[",
            "end": "\\]",
            "beginCaptures": {
                "0": { "name": "punctuation.brackets.square.begin.shim" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.brackets.square.end.shim" }
            },
            "patterns": [
                { "include": "$self" }
            ]
        },
        "curly-braces": {
            "begin": "\\{",
            "end": "\\}",
            "beginCaptures": {
                "0": { "name": "punctuation.section.braces.begin.shim" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.section.braces.end.shim" }
            },
            "patterns": [
                { "include": "$self" }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.separator.comma.shim",
                    "match": ","
                },
                {
                    "name": "punctuation.terminator.semicolon.shim",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.colon.shim",
                    "match": ":"
                }
            ]
        },
        "identifiers": {
            "name": "variable.other.shim",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
    }
}
