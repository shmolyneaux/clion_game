{
    "name": "shimlang",
    "displayName": "Shimlang",
    "description": "Syntax highlighting for the Shimlang programming language",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/shmolyneaux/clion_game"
    },
    "contributes": {
        "languages": [
            {
                "id": "shimlang",
                "aliases": [
                    "Shimlang",
                    "shim"
                ],
                "extensions": [
                    ".shm"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "shimlang",
                "scopeName": "source.shim",
                "path": "./syntaxes/shimlang.tmLanguage.json"
            }
        ]
    }
}
