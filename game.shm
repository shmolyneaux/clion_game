let BUTTON_WIDTH = 500;
let BUTTON_HEIGHT = 50;
let BUTTON_TEXTURE = {
    let data = [];
    let width = BUTTON_WIDTH;
    let height = BUTTON_HEIGHT;

    for y in 0..height {
        for x in 0..width {
            data.append(255 - (x - BUTTON_WIDTH/2).abs().int()); data.append(0); data.append(0);
            data.append(255);
        }
    }

    create_texture(
        width,
        height,
        data,
    )
};


