let EIGHTH = 0.5;
let QUARTER = 1.0;
let DOT_QUARTER = 1.5;
let HALF = 2.0;

struct Note {
    frequency,
    period,
}

struct Wait {
    period,
}

// Korobeiniki ("Tetris Theme A"). The melody and a root bass line are merged
// into a single event stream: a `Note` triggers a sound without advancing time,
// so notes that sound together are emitted back-to-back, then a `Wait` advances
// to the next onset. Bass notes carry their full (HALF) duration so they sustain
// under the melody.
let song = [
    // --- Section A, phrase 1 ---
    // m1: Em
    Note(E5, QUARTER), Note(E2, HALF),
    Wait(QUARTER),
    Note(B4, EIGHTH),
    Wait(EIGHTH),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    Note(D5, QUARTER), Note(E2, HALF),
    Wait(QUARTER),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    Note(B4, EIGHTH),
    Wait(EIGHTH),
    // m2: Am
    Note(A4, QUARTER), Note(A2, HALF),
    Wait(QUARTER),
    Note(A4, EIGHTH),
    Wait(EIGHTH),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    Note(E5, QUARTER), Note(A2, HALF),
    Wait(QUARTER),
    Note(D5, EIGHTH),
    Wait(EIGHTH),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    // m3: B
    Note(B4, DOT_QUARTER), Note(B2, HALF),
    Wait(DOT_QUARTER),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    Note(D5, QUARTER), Note(B2, HALF),
    Wait(QUARTER),
    Note(E5, QUARTER),
    Wait(QUARTER),
    // m4: Em
    Note(C5, QUARTER), Note(E2, HALF),
    Wait(QUARTER),
    Note(A4, QUARTER),
    Wait(QUARTER),
    Note(A4, QUARTER), Note(E2, HALF),
    Wait(QUARTER),
    Wait(QUARTER),

    // --- Section A, phrase 2 ---
    // m5: Dm
    Note(D5, DOT_QUARTER), Note(D2, HALF),
    Wait(DOT_QUARTER),
    Note(F5, EIGHTH),
    Wait(EIGHTH),
    Note(A5, QUARTER), Note(D2, HALF),
    Wait(QUARTER),
    Note(G5, EIGHTH),
    Wait(EIGHTH),
    Note(F5, EIGHTH),
    Wait(EIGHTH),
    // m6: C
    Note(E5, DOT_QUARTER), Note(C2, HALF),
    Wait(DOT_QUARTER),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    Note(E5, QUARTER), Note(C2, HALF),
    Wait(QUARTER),
    Note(D5, EIGHTH),
    Wait(EIGHTH),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    // m7: B
    Note(B4, DOT_QUARTER), Note(B2, HALF),
    Wait(DOT_QUARTER),
    Note(C5, EIGHTH),
    Wait(EIGHTH),
    Note(D5, QUARTER), Note(B2, HALF),
    Wait(QUARTER),
    Note(E5, QUARTER),
    Wait(QUARTER),
    // m8: Am -> Em
    Note(C5, QUARTER), Note(A2, HALF),
    Wait(QUARTER),
    Note(A4, QUARTER),
    Wait(QUARTER),
    Note(A4, QUARTER), Note(E2, HALF),
    Wait(QUARTER),
    Wait(QUARTER),

    // --- Section B ---
    // b1
    Note(E5, HALF), Note(E2, HALF),
    Wait(HALF),
    Note(C5, HALF), Note(C2, HALF),
    Wait(HALF),
    // b2
    Note(D5, HALF), Note(D2, HALF),
    Wait(HALF),
    Note(B4, HALF), Note(B2, HALF),
    Wait(HALF),
    // b3
    Note(C5, HALF), Note(C2, HALF),
    Wait(HALF),
    Note(A4, HALF), Note(A2, HALF),
    Wait(HALF),
    // b4
    Note(Gs4, HALF), Note(E2, HALF),
    Wait(HALF),
    Note(B4, HALF), Note(E2, HALF),
    Wait(HALF),
    // b5
    Note(E5, HALF), Note(E2, HALF),
    Wait(HALF),
    Note(C5, HALF), Note(C2, HALF),
    Wait(HALF),
    // b6
    Note(D5, HALF), Note(D2, HALF),
    Wait(HALF),
    Note(B4, HALF), Note(B2, HALF),
    Wait(HALF),
    // b7
    Note(C5, QUARTER), Note(A2, HALF),
    Wait(QUARTER),
    Note(E5, QUARTER),
    Wait(QUARTER),
    Note(A5, HALF), Note(A2, HALF),
    Wait(HALF),
    // b8
    Note(Gs5, HALF), Note(E2, HALF),
    Wait(HALF),
    Note(E2, HALF),
    Wait(HALF),
];
let current_note = 0;

let BLOCK_SIZE = 32;
fn block_texture(r, g, b) {
    let data = [];
    let size = BLOCK_SIZE;
    let bevel = 4;

    for y in 0..size {
        for x in 0..size {
            // Distance from each edge
            let from_left = x;
            let from_right = size - 1 - x;
            let from_top = y;
            let from_bottom = size - 1 - y;

            let hmix = 0.5;
            let r_highlight = r*(1-hmix) + hmix;
            let g_highlight = g*(1-hmix) + hmix;
            let b_highlight = b*(1-hmix) + hmix;

            let smix = 0.5;
            let r_shadow = r*(1-smix);
            let g_shadow = g*(1-smix);
            let b_shadow = b*(1-smix);

            let r = r;
            let g = g;
            let b = b;

            // Top/left highlight, bottom/right shadow for a 3D bevel
            if from_top < bevel and from_top <= from_left and from_top <= from_right {
                r = r_highlight;
                g = g_highlight;
                b = b_highlight;
            } else if from_left < bevel and from_left <= from_bottom {
                r = r_highlight;
                g = g_highlight;
                b = b_highlight;
            } else if from_bottom < bevel and from_bottom <= from_right {
                r = r_shadow;
                g = g_shadow;
                b = b_shadow;
            } else if from_right < bevel {
                r = r_shadow;
                g = g_shadow;
                b = b_shadow;
            }

            data.append(r);
            data.append(g);
            data.append(b);
            data.append(1.0);
        }
    }

    create_texture(
        size,
        size,
        data,
    )
}

let CYAN_BLOCK_TEXTURE = block_texture(
    r=0.157,
    g=0.627,
    b=0.863,
);

let ORANGE_BLOCK_TEXTURE = block_texture(
    r=0.7,
    g=0.5,
    b=0.1,
);

let RED_BLOCK_TEXTURE = block_texture(
    r=0.7,
    g=0.1,
    b=0.1,
);

let BLUE_BLOCK_TEXTURE = block_texture(
    r=0.1,
    g=0.1,
    b=0.7,
);

let GREEN_BLOCK_TEXTURE = block_texture(
    r=0.1,
    g=0.7,
    b=0.1,
);

let YELLOW_BLOCK_TEXTURE = block_texture(
    r=0.7,
    g=0.7,
    b=0.1,
);

let PURPLE_BLOCK_TEXTURE = block_texture(
    r=0.7,
    g=0.1,
    b=0.7,
);

let BORDER_BLOCK_TEXTURE = block_texture(
    r=0.2,
    g=0.2,
    b=0.2,
);

let EMPTY = 0;
let RED = 1;
let GREEN = 2;
let BLUE = 3;
let YELLOW = 4;
let PURPLE = 5;
let CYAN = 6;
let ORANGE = 7;

let shapes = [
    // RED
    [
        [0, 1],
        [1, 1],
        [1, 0],
    ],
    // GREEN
    [
        [1, 0],
        [1, 1],
        [0, 1],
    ],
    // BLUE
    [
        [0, 1],
